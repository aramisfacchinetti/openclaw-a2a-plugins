{
  "id": "openclaw-a2a-outbound",
  "name": "External A2A Delegation",
  "version": "2.0.0",
  "entry": "./dist/index.js",
  "description": "Delegate requests to external A2A agents and manage delegated tasks.",
  "skills": [
    "./skills"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": false
      },
      "defaults": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "timeoutMs": {
            "type": "integer",
            "minimum": 1,
            "default": 120000
          },
          "cardPath": {
            "type": "string",
            "default": "/.well-known/agent-card.json"
          },
          "preferredTransports": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "JSONRPC",
                "HTTP+JSON",
                "GRPC"
              ]
            },
            "default": [
              "JSONRPC",
              "HTTP+JSON"
            ]
          },
          "serviceParameters": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "default": {}
          }
        }
      },
      "targets": {
        "type": "array",
        "default": [],
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "alias",
            "baseUrl"
          ],
          "properties": {
            "alias": {
              "type": "string"
            },
            "baseUrl": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "cardPath": {
              "type": "string",
              "default": "/.well-known/agent-card.json"
            },
            "preferredTransports": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "JSONRPC",
                  "HTTP+JSON",
                  "GRPC"
                ]
              },
              "default": [
                "JSONRPC",
                "HTTP+JSON"
              ]
            },
            "examples": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "default": {
              "type": "boolean",
              "default": false
            }
          }
        }
      },
      "taskHandles": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "ttlMs": {
            "type": "integer",
            "minimum": 1,
            "default": 86400000
          },
          "maxEntries": {
            "type": "integer",
            "minimum": 1,
            "default": 1000
          }
        }
      },
      "policy": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "acceptedOutputModes": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "normalizeBaseUrl": {
            "type": "boolean",
            "default": true
          },
          "enforceSupportedTransports": {
            "type": "boolean",
            "default": true
          },
          "allowTargetUrlOverride": {
            "type": "boolean",
            "default": false
          }
        }
      }
    }
  }
}
