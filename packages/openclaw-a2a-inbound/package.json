{
  "name": "@aramisfa/openclaw-a2a-inbound",
  "private": true,
  "version": "0.1.0",
  "description": "Inbound A2A channel plugin scaffold for OpenClaw agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aramisfacchinetti/openclaw-a2a-plugins.git"
  },
  "bugs": {
    "url": "https://github.com/aramisfacchinetti/openclaw-a2a-plugins/issues"
  },
  "homepage": "https://github.com/aramisfacchinetti/openclaw-a2a-plugins#readme",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "a2a",
    "agent-to-agent",
    "inbound",
    "channel"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "a2a",
      "label": "A2A Inbound",
      "selectionLabel": "A2A Inbound (HTTP/JSON-RPC)",
      "docsPath": "/channels/a2a",
      "docsLabel": "a2a",
      "blurb": "Expose an OpenClaw agent as an inbound A2A endpoint.",
      "order": 70,
      "aliases": [
        "a2a"
      ]
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck:src": "tsc -b --pretty false",
    "typecheck:tests": "tsc -p tsconfig.tests.json --pretty false",
    "typecheck": "corepack pnpm run typecheck:src && corepack pnpm run typecheck:tests",
    "test": "corepack pnpm run build && node --import tsx --test tests/*.test.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "node ../../scripts/publish-guard.cjs package --package=@aramisfa/openclaw-a2a-inbound"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.10",
    "express": "^5.2.1",
    "openclaw": "2026.3.2"
  },
  "peerDependencies": {
    "openclaw": "2026.3.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.35",
    "tsx": "^4.21.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
